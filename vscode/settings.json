{
    "workbench.startupEditor": "none",
    "python.defaultInterpreterPath": "/bin/python3",
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
        "csv": false,
        "python": false
    },
    "terminal.integrated.suggest.enabled": false,
    "editor.wordWrap": "on",
    "editor.largeFileOptimizations": false,
    "zenMode.hideLineNumbers": false,
    "zenMode.centerLayout": true,
    "zenMode.fullScreen": true,
    "zenMode.hideStatusBar": false,
    "[python]": {
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 80,
    },
    "python.analysis.typeCheckingMode": "standard",
    "cSpell.enabledFileTypes": {
        "*": false
    },
    "cSpell.userWords": [
        "Materialisation",
        "materialise",
        "materialised",
        "materialising",
        "prioritisation",
        "reanalysing",
        "rematerialise",
        "rematerialising",
        "utilise"
    ],
    "claudeCode.preferredLocation": "panel",
    "github.copilot.nextEditSuggestions.enabled": true,
    "editor.largeFileOptimizations": false,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "editor.lineNumbers": "relative",
    "python.createEnvironment.trigger": "off",
    "jupyter.debugJustMyCode": false,
    "debugpy.debugJustMyCode": false,
    "git.openRepositoryInParentFolders": "never",
    "workbench.colorTheme": "Doom Emacs",
    "workbench.activityBar.location": "top",
    "makefile.configureOnOpen": false,
    "git.suggestSmartCommit": false,
    "workbench.editor.showTabs": "single",
    "editor.minimap.enabled": false,
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.arguments": [
        "--clang-tidy",
        "--completion-style=detailed",
        "--header-insertion=iwyu",
        "--compile-commands-dir=${workspaceFolder}/build"
    ],
    "clangd.path": "/home/oscar/.config/Code/User/globalStorage/llvm-vs-code-extensions.vscode-clangd/install/22.1.0/clangd_22.1.0/bin/clangd",
    "zenMode.showTabs": "single",
    "chat.disableAIFeatures": true,
    "editor.cursorSurroundingLines": 100,
}
